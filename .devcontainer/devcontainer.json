{
  "name": "R3LIVE ROS Noetic",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "USERNAME": "vscode"
    }
  },
  "workspaceFolder": "/workspaces/r3live",
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "initializeCommand": "mkdir -p \"${localEnv:HOME}/r3live_data/output\" && touch \"${localEnv:HOME}/.Xauthority\"",
  "mounts": [
    "source=${localEnv:HOME}/r3live_data,target=/data,type=bind,consistency=cached",
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
    "source=${localEnv:HOME}/.Xauthority,target=/home/vscode/.Xauthority,type=bind,readonly"
  ],
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    "XAUTHORITY": "/home/vscode/.Xauthority",
    "QT_X11_NO_MITSHM": "1"
  },
  "runArgs": [
    "--init"
  ],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "shutdownAction": "stopContainer",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-iot.vscode-ros"
      ]
    }
  }
}

